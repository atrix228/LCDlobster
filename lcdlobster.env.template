# ==========================================================
# LCDlobster configuration — edit before first boot
# Copy this file to lcdlobster.env and fill in your values.
# lcdlobster.env is gitignored — credentials stay off GitHub.
# ==========================================================

# ----------------------------------------------------------
# WiFi networks — up to 5, tried in priority order (1 first)
# ----------------------------------------------------------
WIFI_1_SSID=
WIFI_1_PASS=

WIFI_2_SSID=
WIFI_2_PASS=

WIFI_3_SSID=
WIFI_3_PASS=

WIFI_4_SSID=
WIFI_4_PASS=

WIFI_5_SSID=
WIFI_5_PASS=

# ----------------------------------------------------------
# AI Provider API Keys — leave blank to skip that provider
# ----------------------------------------------------------
MINIMAX_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Provider priority (comma-separated, first valid key wins)
PROVIDER_PRIORITY=minimax,openrouter,anthropic

# Model overrides (optional — defaults shown)
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
MINIMAX_MODEL=MiniMax-Text-01
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ----------------------------------------------------------
# Other settings
# ----------------------------------------------------------
WHATSAPP_ENABLED=true
HTTP_PORT=3000

# SSH password for the pi user (default: lcdlobster)
PI_PASSWORD=lcdlobster
